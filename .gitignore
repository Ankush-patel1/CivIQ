# =============================================
#  CivIQ — Root .gitignore
# =============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyd
*.pyo
*.pdb

# Virtual environments
venv/
.venv/
env/
ENV/
.env
.env.*
*.env

# Python build/dist
build/
dist/
*.egg-info/
*.egg

# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.cache/
.parcel-cache/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS & IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# --- Secrets ---
*.pem
*.key
*.cert
secrets/

# --- Large binary / media ---
*.docx
*.pdf
*.zip
*.tar.gz
*.mp4
*.mov

# --- Misc ---
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
